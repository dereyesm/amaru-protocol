[0.000, "o", "\u001b[22A\u001b[53C\u001b[7m \u001b[7m#\u001b[7m \u001b[7m=\u001b[7m=\u001b[7m=\u001b[7m \u001b[7m1\u001b[7m.\u001b[7m \u001b[7mS\u001b[7my\u001b[7mn\u001b[7mc\u001b[7m \u001b[7mv\u001b[7me\u001b[7mr\u001b[7mi\u001b[7mf\u001b[7my\u001b[7m \u001b[7m=\u001b[7m=\u001b[7m=\u001b[1B\u001b[27m\r\u001b[7m \u001b[7m \u001b[7mg\u001b[7mi\u001b[7mt\u001b[7m \u001b[7mr\u001b[7me\u001b[7mv\u001b[7m-\u001b[7mp\u001b[7ma\u001b[7mr\u001b[7ms\u001b[7me\u001b[7m \u001b[7m-\u001b[7m-\u001b[7ms\u001b[7mh\u001b[7mo\u001b[7mr\u001b[7mt\u001b[7m \u001b[7mH\u001b[7mE\u001b[7mA\u001b[7mD\u001b[1B\u001b[27m\r\u001b[7m \u001b[7m \u001b[7mg\u001b[7mi\u001b[7mt\u001b[7m \u001b[7ml\u001b[7mo\u001b[7mg\u001b[7m \u001b[7m-\u001b[7m-\u001b[7mo\u001b[7mn\u001b[7me\u001b[7ml\u001b[7mi\u001b[7mn\u001b[7me\u001b[7m \u001b[7m-\u001b[7m3\u001b[1B\u001b[27m\r\u001b[7m \u001b[7m \u001b[7ma\u001b[7mm\u001b[7ma\u001b[7mr\u001b[7mu\u001b[7m \u001b[7m-\u001b[7m-\u001b[7mv\u001b[7me\u001b[7mr\u001b[7ms\u001b[7mi\u001b[7mo\u001b[7mn\u001b[1B\u001b[27m\r\u001b[7m \u001b[7m \u001b[7ma\u001b[7mm\u001b[7ma\u001b[7mr\u001b[7mu\u001b[7m \u001b[7mh\u001b[7mu\u001b[7mb\u001b[7m \u001b[7ms\u001b[7mt\u001b[7ma\u001b[7mt\u001b[7mu\u001b[7ms\u001b[1B\u001b[27m\r\u001b[7m \u001b[7m \u001b[7ma\u001b[7mm\u001b[7ma\u001b[7mr\u001b[7mu\u001b[7m \u001b[7mh\u001b[7mu\u001b[7mb\u001b[7m \u001b[7mr\u001b[7mo\u001b[7ms\u001b[7mt\u001b[7me\u001b[7mr\u001b[1B\u001b[27m\r\u001b[7m \u001b[7m \u001b[7ma\u001b[7mm\u001b[7ma\u001b[7mr\u001b[7mu\u001b[7m \u001b[7mh\u001b[7mu\u001b[7mb\u001b[7m \u001b[7mp\u001b[7me\u001b[7me\u001b[7mr\u001b[7ms\u001b[2B\u001b[27m\r\u001b[7m \u001b[7m \u001b[7m#\u001b[7m \u001b[7m=\u001b[7m=\u001b[7m=\u001b[7m \u001b[7m2\u001b[7m.\u001b[7m \u001b[7mT\u001b[7me\u001b[7ms\u001b[7mt\u001b[7m \u001b[7m1\u001b[7m8\u001b[7m \u001b[7me\u001b[7mv\u001b[7mi\u001b[7md\u001b[7me\u001b[7mn\u001b[7mc\u001b[7me\u001b[7m \u001b[7m—\u001b[7m \u001b[7md\u001b[7mo\u001b[7mw\u001b[7mn\u001b[7mg\u001b[7mr\u001b[7m
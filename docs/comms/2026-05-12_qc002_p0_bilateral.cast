[0.000, "o", " \u001b[1m\u001b[30m# === 1. Sync verify ===\u001b[0m\u001b[39m\u001b[K\r\r\n  \u001b[32mgit\u001b[39m rev-parse --short HEAD\u001b[K\r\r\n  \u001b[32mgit\u001b[39m log --oneline -3\u001b[K\r\r\n  \u001b[32mamaru\u001b[39m --version\u001b[K\r\r\n  \u001b[32mamaru\u001b[39m hub status\u001b[K\r\r\n  \u001b[32mamaru\u001b[39m hub roster\u001b[K\r\r\n  \u001b[32mamaru\u001b[39m hub peers\u001b[K\r\r\n\u001b[K\r\r\n  \u001b[1m\u001b[30m# === 2. Test 18 evidence — downgrade protection HIT ===\u001b[0m\u001b[39m\u001b[K\r\r\n  \u001b[32mpython3\u001b[39m -c \u001b[33m\"\u001b[39m\u001b[K\r\r\n\u001b[33m  import asyncio, json, websockets\u001b[39m\u001b[K\r\r\n\u001b[33m  async def t():\u001b[39m\u001b[K\r\r\n\u001b[33m      async with websockets.connect('ws://127.0.0.1:8443', open_timeout=5) as ws:\u001b[39m\u001b[K\r\r\n\u001b[33m          await ws.send(json.dumps({'type':'hello','clan_id':'momoshod','sign_pub':'85a940d9b5a2f084c660087c7377a07fa8128758a48bd6b55016fd32f7cffe5f'}))\u001b[39m\u001b[K\r\r\n\u001b[33m          print('Legacy HELLO →', await asyncio.wait_for(ws.recv(),5))\u001b[39m\u001b[K\r\r\n\u001b[33m  asyncio.run(t())\u001b[39m\u001b[K\r\r\n\u001b[33m  \"\u001b[39m\u001b[K\r\r\n\u001b[K\r\r\n  \u001b[1m\u001b[30m# === 3. Tests 1-3 tráfico real bilateral ===\u001b[0m\u001b[39m\u001b[K\r\r\n  \u001b[32mamaru\u001b[39m send jei \u001b[33m\"QC002-T1 multicast round-trip\""]

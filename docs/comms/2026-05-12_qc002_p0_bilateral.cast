[0.000, "o", " \u001b[7m \u001b[7me\u001b[7mc\u001b[7mh\u001b[7mo\u001b[7m \u001b[7m\"\u001b[7m=\u001b[7m=\u001b[7m=\u001b[7m \u001b[7mQ\u001b[7mC\u001b[7m0\u001b[7m0\u001b[7m2\u001b[7m \u001b[7mP\u001b[7mh\u001b[7ma\u001b[7ms\u001b[7me\u001b[7m \u001b[7m1\u001b[7m \u001b[7mc\u001b[7mu\u001b[7mt\u001b[7m \u001b[7mD\u001b[7mA\u001b[7mN\u001b[7mI\u001b[7m \u001b[7ms\u001b[7mi\u001b[7md\u001b[7me\u001b[7m \u001b[7mc\u001b[7mo\u001b[7mm\u001b[7mp\u001b[7ml\u001b[7me\u001b[7mt\u001b[7me\u001b[7m \u001b[7m=\u001b[7m=\u001b[7m=\u001b[7m\"\u001b[1B\u001b[27m\r\u001b[7m \u001b[7m \u001b[7md\u001b[7ma\u001b[7mt\u001b[7me\u001b[7m \u001b[7m\"\u001b[7m+\u001b[7m%\u001b[7mY\u001b[7m-\u001b[7m%\u001b[7mm\u001b[7m-\u001b[7m%\u001b[7md\u001b[7m \u001b[7m%\u001b[7mH\u001b[7m:\u001b[7m%\u001b[7mM\u001b[7m:\u001b[7m%\u001b[7mS\u001b[7m \u001b[7m%\u001b[7mZ\u001b[7m\"\u001b[1B\u001b[27m\r\u001b[7m \u001b[7m \u001b[7me\u001b[7mx\u001b[7mi\u001b[7mt\u001b[27m\r\r\n\u001b[K"]

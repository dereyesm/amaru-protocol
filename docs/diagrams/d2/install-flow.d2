# HERMES Install Flow — ARC-4601
# Brand: #1A1A2E #00D4AA #F5A623 #27AE60 #E74C3C #7F8C8D

direction: down

# ── Entry point ────────────────────────────────────────────────────────────────

detect: 1. detect_platform() {
  shape: step
  style.font-size: 24
  style.fill: "#1A1A2E"
  style.font-color: "#00D4AA"
  style.stroke: "#00D4AA"
  style.stroke-width: 2
}

# ── Platform decision ───────────────────────────────────────────────────────────

platform: Platform? {
  shape: diamond
  style.font-size: 22
  style.fill: "#F5A623"
  style.font-color: "#1A1A2E"
  style.stroke: "#F5A623"
  style.stroke-width: 3
}

# ── Common steps (pre-service) ──────────────────────────────────────────────────

init: 2. init_clan_if_needed() {
  shape: step
  style.font-size: 24
  style.fill: "#1A1A2E"
  style.font-color: "#00D4AA"
  style.stroke: "#00D4AA"
  style.stroke-width: 2
}

clan_dir: ~/.hermes/ + gateway.json {
  shape: cylinder
  style.font-size: 20
  style.fill: "#1A1A2E"
  style.font-color: "#7F8C8D"
  style.stroke: "#7F8C8D"
  style.stroke-width: 1
}

keygen: 3. generate_keypair() {
  shape: step
  style.font-size: 24
  style.fill: "#1A1A2E"
  style.font-color: "#00D4AA"
  style.stroke: "#00D4AA"
  style.stroke-width: 2
}

keys_note: Ed25519 (sign) + X25519 (DH) {
  shape: stored_data
  style.font-size: 18
  style.fill: "#1A1A2E"
  style.font-color: "#7F8C8D"
  style.stroke: "#7F8C8D"
  style.stroke-width: 1
  style.stroke-dash: 5
}

agent_cfg: 4. add_agent_node_section() {
  shape: step
  style.font-size: 24
  style.fill: "#1A1A2E"
  style.font-color: "#00D4AA"
  style.stroke: "#00D4AA"
  style.stroke-width: 2
}

# ── Platform-specific service install ──────────────────────────────────────────

svc: 5. install_service() {
  style.font-size: 26
  style.fill: "#1A1A2E"
  style.font-color: "#F5A623"
  style.stroke: "#F5A623"
  style.stroke-width: 3
  style.border-radius: 8

  mac: LaunchAgent {
    shape: step
    style.font-size: 20
    style.fill: "#1A1A2E"
    style.font-color: "#F5A623"
    style.stroke: "#F5A623"
    style.stroke-width: 1
  }

  linux: systemd {
    shape: step
    style.font-size: 20
    style.fill: "#1A1A2E"
    style.font-color: "#F5A623"
    style.stroke: "#F5A623"
    style.stroke-width: 1
  }

  win: schtasks {
    shape: step
    style.font-size: 20
    style.fill: "#1A1A2E"
    style.font-color: "#F5A623"
    style.stroke: "#F5A623"
    style.stroke-width: 1
  }
}

# ── Common steps (post-service) ─────────────────────────────────────────────────

hooks: 6. install_hooks() {
  shape: step
  style.font-size: 24
  style.fill: "#1A1A2E"
  style.font-color: "#00D4AA"
  style.stroke: "#00D4AA"
  style.stroke-width: 2
}

hooks_note: ~/.claude/settings.json (3 hooks merged) {
  shape: stored_data
  style.font-size: 18
  style.fill: "#1A1A2E"
  style.font-color: "#7F8C8D"
  style.stroke: "#7F8C8D"
  style.stroke-width: 1
  style.stroke-dash: 5
}

daemon: 7. daemon start {
  shape: step
  style.font-size: 24
  style.fill: "#27AE60"
  style.font-color: "#fff"
  style.stroke: "#27AE60"
  style.stroke-width: 2
}

pid_note: Agent Node PID {
  shape: stored_data
  style.font-size: 18
  style.fill: "#1A1A2E"
  style.font-color: "#7F8C8D"
  style.stroke: "#7F8C8D"
  style.stroke-width: 1
  style.stroke-dash: 5
}

notify: 8. send_notification() {
  shape: step
  style.font-size: 24
  style.fill: "#27AE60"
  style.font-color: "#fff"
  style.stroke: "#27AE60"
  style.stroke-width: 2
}

connected: "You're connected!" {
  shape: document
  style.font-size: 26
  style.fill: "#27AE60"
  style.font-color: "#1A1A2E"
  style.stroke: "#27AE60"
  style.stroke-width: 3
}

# ── Main flow ───────────────────────────────────────────────────────────────────

detect -> platform {
  style.stroke: "#00D4AA"
  style.stroke-width: 5
  style.animated: true
}

platform -> init: macOS / Linux / Windows {
  style.stroke: "#F5A623"
  style.stroke-width: 4
  style.animated: true
  style.font-size: 18
  style.bold: true
}

init -> clan_dir {
  style.stroke: "#7F8C8D"
  style.stroke-width: 2
  style.stroke-dash: 5
  style.font-size: 16
}

init -> keygen {
  style.stroke: "#00D4AA"
  style.stroke-width: 5
  style.animated: true
}

keygen -> keys_note {
  style.stroke: "#7F8C8D"
  style.stroke-width: 2
  style.stroke-dash: 5
  style.font-size: 16
}

keygen -> agent_cfg {
  style.stroke: "#00D4AA"
  style.stroke-width: 5
  style.animated: true
}

agent_cfg -> svc {
  style.stroke: "#F5A623"
  style.stroke-width: 5
  style.animated: true
  style.font-size: 20
  style.bold: true
}

# Platform branching inside svc container

platform -> svc.mac: macOS {
  style.stroke: "#F5A623"
  style.stroke-width: 2
  style.stroke-dash: 5
  style.font-size: 16
}

platform -> svc.linux: Linux {
  style.stroke: "#F5A623"
  style.stroke-width: 2
  style.stroke-dash: 5
  style.font-size: 16
}

platform -> svc.win: Windows {
  style.stroke: "#F5A623"
  style.stroke-width: 2
  style.stroke-dash: 5
  style.font-size: 16
}

svc -> hooks: service registered {
  style.stroke: "#00D4AA"
  style.stroke-width: 5
  style.animated: true
  style.font-size: 20
  style.bold: true
}

hooks -> hooks_note {
  style.stroke: "#7F8C8D"
  style.stroke-width: 2
  style.stroke-dash: 5
  style.font-size: 16
}

hooks -> daemon {
  style.stroke: "#27AE60"
  style.stroke-width: 5
  style.animated: true
}

daemon -> pid_note {
  style.stroke: "#7F8C8D"
  style.stroke-width: 2
  style.stroke-dash: 5
  style.font-size: 16
}

daemon -> notify {
  style.stroke: "#27AE60"
  style.stroke-width: 5
  style.animated: true
}

notify -> connected {
  style.stroke: "#27AE60"
  style.stroke-width: 5
  style.animated: true
}
